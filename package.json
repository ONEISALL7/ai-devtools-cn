{
  "name": "ai-devtools-cn",
  "version": "0.17.5",
  "description": "Chinese AI developer tooling templates and maintenance workflows.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "ai-devtools-cn": "scripts/template-cli.mjs"
  },
  "files": [
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "docs",
    "examples",
    "templates",
    "scripts/template-cli.mjs"
  ],
  "keywords": [
    "ai",
    "developer-tools",
    "templates",
    "open-source",
    "maintenance",
    "pr-review",
    "issue-triage",
    "ci"
  ],
  "homepage": "https://github.com/ONEISALL7/ai-devtools-cn#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ONEISALL7/ai-devtools-cn.git"
  },
  "bugs": {
    "url": "https://github.com/ONEISALL7/ai-devtools-cn/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"!node_modules/**\" \"!work/**\"",
    "test": "npm run test:cli && npm run test:date && npm run test:metrics && npm run lint:md",
    "test:cli": "node scripts/test-template-cli.mjs",
    "test:date": "node scripts/test-date-utils.mjs",
    "test:metrics": "node scripts/test-metrics-snapshot.mjs",
    "pack:dry-run": "npm pack --dry-run",
    "metrics:snapshot": "node scripts/metrics-snapshot.mjs",
    "templates:help": "node scripts/template-cli.mjs help",
    "templates:list": "node scripts/template-cli.mjs list",
    "templates:examples": "node scripts/template-cli.mjs examples",
    "templates:recipes": "node scripts/template-cli.mjs recipes",
    "templates:contribute": "node scripts/template-cli.mjs contribute",
    "templates:launch": "node scripts/template-cli.mjs launch",
    "templates:handoff": "node scripts/template-cli.mjs handoff",
    "templates:pr-pack": "node scripts/template-cli.mjs pr-pack",
    "templates:review-pr": "node scripts/template-cli.mjs review-pr",
    "templates:claim": "node scripts/template-cli.mjs claim",
    "templates:starter": "node scripts/template-cli.mjs starter",
    "templates:recommend": "node scripts/template-cli.mjs recommend",
    "templates:search": "node scripts/template-cli.mjs search",
    "templates:show": "node scripts/template-cli.mjs show",
    "templates:new": "node scripts/template-cli.mjs new",
    "templates:kit": "node scripts/template-cli.mjs kit",
    "templates:trial": "node scripts/template-cli.mjs trial",
    "templates:feedback": "node scripts/template-cli.mjs feedback",
    "templates:outreach": "node scripts/template-cli.mjs outreach",
    "templates:adoption": "node scripts/template-cli.mjs adoption",
    "templates:evidence": "node scripts/template-cli.mjs evidence",
    "templates:application": "node scripts/template-cli.mjs application",
    "templates:publish-status": "node scripts/template-cli.mjs publish-status",
    "templates:doctor": "node scripts/template-cli.mjs doctor",
    "templates:publish-check": "node scripts/template-cli.mjs publish-check",
    "templates:validate": "node scripts/template-cli.mjs validate"
  },
  "devDependencies": {
    "markdownlint-cli2": "^0.22.1"
  }
}
